#entry:selected {
  background-color: #eeeeee;
}

#text:selected{
  color: #000000;
}

#input {
  border: none;
  border-radius: 0px;
  font-size: 18px;
}

#text {
  margin-left: 1em;
}

#scroll {
    border-radius: 5px;
    font-size:16px;
}

window {
  opacity: 0.9;
  border: 2px solid #2e3440;
  background-color: #222222;
  color: #eeeeee;
  border-radius: 0px;
}
