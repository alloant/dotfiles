// vim:ft=json
{
    "custom/bluetooth": {
        "exec": "$HOME/.config/waybar/modules/bluetooth.sh",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "on": "",
            "off": "<span color='#b30000'></span>"
        },
        "on-click": "wofi-bluetooth",
        "interval": 5
    }
}
