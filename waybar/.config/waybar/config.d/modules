        },
        "on-click": "$HOME/.config/waybar_river/modules/waybar-toggle-wlsunset.sh; pkill -SIGRTMIN+6 waybar",
        "exec-on-event": "true",
        "signal": 6,
        "interval": 50
    },
    "custom/weather": {
