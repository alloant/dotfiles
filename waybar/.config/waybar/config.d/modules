    "custom/bluetooth": {
        "exec": "$HOME/.config/waybar_river/modules/waybar-bluetooth",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "on": "’Ŗō",
            "off": "<span color='#b30000'>’Ŗō</span>"
